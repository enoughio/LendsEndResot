generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

// enum RoomStatus {
//   AVAILABLE
//   UNAVAILABLE
// }

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REFUNDED
  FAILED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum BookingType {
  STAY
  VISIT
}

enum VisitPackage {
  FULL_DAY
  HALF_DAY
  SHORT_VISIT
}




model Users {

  id String @id @default(cuid())
  name String
  email String  
  password String
  role Role @default(USER)
  phone String
  emailVerified Boolean @default(true)
  phoneVerified Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // opposite relation fields
  bookings Bookings[]
  events Events[]

}



model RoomTypes {

  id String @id @default(cuid())
  name String
  capacity Int
  bedType String
  description String
  basePrice Float
  size_sqft String
  amenities String[]

  // opposite relation field
  rooms Rooms[]   // one to many
}


enum RoomStatus {
  AVAILABLE
  INACTIVE
  MAINTENANCE
}


model Rooms { 

  id String @id @default(cuid())
  roomNo String
  
  // foreign key
  roomTypeId String 
  // relation definition
  roomType RoomTypes @relation( fields: [roomTypeId], references: [id] )
  roomStatus RoomStatus @default(AVAILABLE)
  createAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  bookings Bookings[]

}


model Activities {

  id String @id @default(cuid())
  name String
  duration Float
  Price Float
  status String

  createAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // bookings Bookings[]

  // this is a many to many relationship 
  bookingActivities BookingActivities[]


}


model VisitPackages {

  id String @id @default(cuid())
  name String
  duration Float
  basePrice Float
  image String[]
  description String?

  createdAt DateTime @default(now())
  updated DateTime @updatedAt

  bookings Bookings[] 
  
}


model Bookings {

  id String @id @default(cuid())
  
  //foreign key
  userId String
  // relation definition
  users Users @relation( fields: [userId], references: [id] ) 
  
  // foreign key
  roomId String ?
  // relation definition
  rooms Rooms ? @relation( fields: [roomId], references: [id] )

  visitPackageId String ?
  visitPackage VisitPackages ? @relation( fields: [visitPackageId], references: [id] )

  // activitiesId String ? 
  // activities Activities ?  @relation( fields: [activitiesId], references: [id] )

  bookingActivities BookingActivities[]

  guests Int @default(1)
  bookingTypes BookingType @default(STAY)
  status String
  visitDate DateTime ?
  totalAmount String
  currency String @default("INR")
  
  razorPayOrderId String ?
  razorPayPaymentId String ?
  razorPaySignature String ? 

  paymentStatus PaymentStatus @default(PENDING)

  createdAt DateTime @default(now())
  updated DateTime @updatedAt

}

model BookingActivities {
  id String @id @default(cuid())

  // foreign key
  bookingId String
  activityId String

  // relation definitions 
  booking  Bookings   @relation(fields: [bookingId], references: [id])
  activity Activities @relation(fields: [activityId], references: [id])

  createdAt DateTime @default(now())

  @@unique([bookingId, activityId])
}


model Events { 

  id String @id @default(cuid())
  name String
  fromDate DateTime
  tillDate DateTime
  description String
  images String[] 
  Links String[]
  price Float

  attendId String 
  attendee Users @relation(fields: [attendId], references: [id]) 

  createdAt DateTime @default(now())
  updated DateTime @updatedAt

}



