// Prisma schema (normalized)
// Generator and datasource
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Enums
enum Role {
  USER
  ADMIN
}

enum RoomStatus {
  AVAILABLE
  INACTIVE
  MAINTENANCE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REFUNDED
  FAILED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum BookingType {
  STAY
  VISIT
}

enum VisitPackageType {
  FULL_DAY
  HALF_DAY
  SHORT_VISIT
}

enum PackageStatus {
  ACTIVE
  INACTIVE
}

// Models

model User {
  id String @id @default(cuid())
  name String
  email String @unique
  password String
  role Role @default(USER)
  phone String
  emailVerified Boolean @default(true)
  phoneVerified Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings Booking[]
  events Event[]
}

model RoomType {
  id String @id @default(cuid())
  name String
  capacity Int
  bedType String
  description String
  basePrice Float
  size_sqft String
  amenities String[]
  totalRooms Int @default(0)
    //opposite relation
  rooms Room[]
}

model Room {
  id String @id @default(cuid())
  roomNo String @unique
 
 // foreign key
  roomTypeId String
  // relation definition
  roomType RoomType @relation(fields: [roomTypeId], references: [id])
  floor Int?
  view String?
  roomStatus RoomStatus @default(AVAILABLE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings Booking[]
}

model Activity {
  id String @id @default(cuid())
  name String
  duration Float
  price Float
  status String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookingActivities BookingActivity[]
}

model VisitPackage {
  id String @id @default(cuid())
  name String
  packageType VisitPackageType @default(SHORT_VISIT)
  duration Float
  basePrice Float
  maxActivity Int @default(1)
  maxGroupSize Int @default(1)
  timing String?
  includes String[]
  status PackageStatus @default(ACTIVE)
  image String[]
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings Booking[]
}

model Booking {
  id String @id @default(cuid())

  userId String?
  user User? @relation(fields: [userId], references: [id])

  roomId String?
  room Room? @relation(fields: [roomId], references: [id])

  visitPackageId String?
  visitPackage VisitPackage? @relation(fields: [visitPackageId], references: [id])

  bookingActivities BookingActivity[]

  // guest details captured in step-2 of booking flow
  guestName String?
  guestEmail String?
  guestPhone String?
  specialRequest String?

  // stay fields
  checkIn DateTime?
  checkOut DateTime?

  guests Int @default(1)
  bookingType BookingType @default(STAY)
  status BookingStatus @default(PENDING)
  visitDate DateTime?

  // amounts in smallest currency unit (paise)
  totalAmount Float
  currency String @default("INR")

  razorPayOrderId String?
  razorPayPaymentId String?
  razorPaySignature String?

  paymentStatus PaymentStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // soft delete
  deletedAt DateTime?

  @@index([userId])
  @@index([roomId])
  @@index([status])
  @@index([visitPackageId])
}

model BookingActivity {
  id String @id @default(cuid())

  bookingId String
  activityId String

  booking Booking @relation(fields: [bookingId], references: [id])
  activity Activity @relation(fields: [activityId], references: [id])

  createdAt DateTime @default(now())

  @@unique([bookingId, activityId])
  @@index([bookingId])
  @@index([activityId])
}

model Event {
  id String @id @default(cuid())
  name String
  fromDate DateTime
  tillDate DateTime
  description String
  images String[]
  links String[]
  price Float

  attendeeId String
  attendee User @relation(fields: [attendeeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


